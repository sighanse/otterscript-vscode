{
  "name": "otterscript-vscode",
  "displayName": "OtterScript Language Extension",
  "description": "Syntax highlighting, snippets, and function support for OtterScript",
  "publisher": "sighanse",
  "author": {
    "name": "Sigurd Hansen",
    "email": "sigurd.hansen@gmail.com",
    "url": "https://github.com/sighanse"
  },
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/sighanse/otterscript-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/sighanse/otterscript-vscode/issues"
  },
  "homepage": "https://github.com/sighanse/otterscript-vscode#readme",
  "markdown": "github",
  "license": "MIT",
  "version": "0.2.1",
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jsonc-parser": "^3.3.1",
    "ovsx": "^0.10.12"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "otterscript",
    "otter",
    "inedo",
    "proget",
    "automation",
    "devops",
    "configuration-management"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:otterscript"
  ],
  "contributes": {
    "languages": [
      {
        "id": "otterscript",
        "aliases": [
          "OtterScript",
          "otterscript"
        ],
        "extensions": [
          ".otter",
          ".oscript"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "otterscript",
        "scopeName": "source.otterscript",
        "path": "./syntaxes/otterscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "otterscript",
        "path": "./snippets/otterscript.json"
      }
    ],
    "configuration": {
      "title": "OtterScript",
      "properties": {
        "otterscript.completion.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable auto-completion suggestions"
        },
        "otterscript.signatureHelp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable signature help for functions and operations"
        },
        "otterscript.hover.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover information for functions and operations"
        }
      }
    },
    "colors": [
      {
        "id": "otterscript.errorBackground",
        "description": "Background color for syntax errors",
        "defaults": {
          "dark": "#FF000022",
          "light": "#FF000022"
        }
      },
      {
        "id": "otterscript.warningBackground",
        "description": "Background color for warnings",
        "defaults": {
          "dark": "#FFA50022",
          "light": "#FFA50022"
        }
      }
    ],
    "commands": [
      {
        "command": "otterscript.fixAll",
        "title": "Fix All Issues",
        "category": "OtterScript",
        "icon": "$(check-all)"
      }
    ],
    "keybindings": [
      {
        "command": "otterscript.fixAll",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f",
        "when": "editorLangId == otterscript && editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "otterscript.fixAll",
          "group": "2_fix@1",
          "when": "editorLangId == otterscript && editorTextFocus"
        }
      ],
      "commandPalette": [
        {
          "command": "otterscript.fixAll",
          "when": "editorLangId == otterscript"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "lint:ci": "eslint . --max-warnings=0 --cache",
    "package": "vsce package --no-yarn",
    "vscode:prepublish": "npm run lint:ci",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish --no-dependencies"
  }
}
