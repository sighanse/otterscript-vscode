{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["vscode"]
  },
  "typeAcquisition": {
    "enable": false
  },
  "include": [
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "test/**",
    ".github/**",
    "images/**",
    "snippets/**",
    "syntaxes/**",
    "out/**"
  ]
}
